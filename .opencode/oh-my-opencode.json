{
  "$schema": "https://zai-coding-plan.github.io/opencode/schemas/oh-my-opencode.json",
  "models": {
    "default": "saia/glm-4.7",
    "fast": "saia/glm-4.7",
    "orchestrator": "saia/glm-4.7",
    "reasoning": "saia/glm-4.7",
    "code": "saia/glm-4.7",
    "visual": "saia/mistral-large-3"
  },
  "agents": {
    "build": {
      "model": "saia/glm-4.7",
      "description": "Code implementation and file editing"
    },
    "explore": {
      "model": "saia/glm-4.7",
      "description": "Codebase search and context gathering"
    },
    "librarian": {
      "model": "saia/glm-4.7",
      "description": "Documentation and library research"
    },
    "oracle": {
      "model": "saia/glm-4.7",
      "description": "Architecture and debugging consultation"
    },
    "metis": {
      "model": "saia/glm-4.7",
      "description": "Pre-planning analysis"
    },
    "momus": {
      "model": "saia/glm-4.7",
      "description": "Plan review and critique"
    },
    "multimodal-looker": {
      "model": "saia/glm-4.7",
      "description": "Media file analysis"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "saia/mistral-large-3",
      "temperature": 0.8,
      "description": "Frontend, UI/UX, design, styling, animation, SVG graphics"
    },
    "ultrabrain": {
      "model": "saia/glm-4.7",
      "temperature": 0.1,
      "description": "Hard logic, architecture decisions, algorithms"
    },
    "deep": {
      "model": "saia/glm-4.7",
      "temperature": 0.2,
      "description": "Autonomous problem-solving, thorough research"
    },
    "artistry": {
      "model": "saia/glm-4.7",
      "temperature": 0.8,
      "description": "Creative approaches beyond standard patterns"
    },
    "quick": {
      "model": "saia/glm-4.7",
      "temperature": 0.3,
      "description": "Trivial tasks - single file changes, typo fixes"
    },
    "unspecified-low": {
      "model": "saia/glm-4.7",
      "temperature": 0.3,
      "description": "Tasks that don't fit other categories, low effort"
    },
    "unspecified-high": {
      "model": "saia/glm-4.7",
      "temperature": 0.4,
      "description": "Tasks that don't fit other categories, high effort"
    },
    "writing": {
      "model": "saia/glm-4.7",
      "temperature": 0.5,
      "description": "Documentation, prose, technical writing"
    }
  },
  "project": {
    "name": "openDesk Edu",
    "description": "openDesk + Educational Services for Universities - Kubernetes deployment with Helm",
    "stack": "Helm, Kubernetes, SAML/OIDC, ILIAS, Moodle, BigBlueButton",
    "conventions": {
      "colors": {
        "primary": "#571EFA",
        "dark": "#341291",
        "accent": "#927AFA"
      },
      "svgIcons": {
        "viewBox": "111x111",
        "borderRadius": 20,
        "fillOnly": true,
        "noText": true,
        "noEmoji": true
      }
    }
  }
}
